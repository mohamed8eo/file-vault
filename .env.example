# Database
DB_URL=postgres://admin:secret123@localhost:5432/file_vault?sslmode=disable

# Server
PORT=3000
IS_PRODUCTION=false

# JWT Secrets (generate with: go run -e "import 'encoding/base64'; b, _ := base64.StdEncoding.EncodeString(make([]byte, 32)); print(b)")
ACCESS_TOKEN_SECRET=your-base64-encoded-32-byte-secret
REFRESH_TOKEN_SECRET=your-base64-encoded-32-byte-secret

# Redis (use upstash or local redis)
REDIS_URL=redis://localhost:6379

# AWS S3
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# OAuth - Google (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google/callback

# OAuth - GitHub (optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URL=http://localhost:3000/auth/github/callback